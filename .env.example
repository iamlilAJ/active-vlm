# OpenAI-compatible VLM endpoint
OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=replace-me
CV_AGENT_MODEL=Qwen3-VL-30B-A3B-Instruct

# Cropping MCP server
CV_AGENT_CROPPING_MCP_URL=https://your-cropping-mcp-server/mcp

# Optional MCP servers for custom configs
# CV_AGENT_OCR_MCP_URL=https://your-ocr-mcp-server/mcp
# CV_AGENT_DETECTION_MCP_URL=https://your-detection-mcp-server/mcp
# CV_AGENT_SEGMENTATION_MCP_URL=https://your-segmentation-mcp-server/mcp
# CV_AGENT_DEPTH_ESTIMATION_MCP_URL=https://your-depth-estimation-mcp-server/mcp

# MinIO/S3-compatible object storage for benchmark images
CV_AGENT_MINIO_ENDPOINT=host:port
CV_AGENT_MINIO_ACCESS_KEY=replace-me
CV_AGENT_MINIO_SECRET_KEY=replace-me
CV_AGENT_MINIO_BUCKET=cv-agent
CV_AGENT_MINIO_SECURE=false

# Local benchmark files
MME_DATA_PATH=/path/to/MME-RealWorld-Lite.json
MME_IMAGE_DIR=/path/to/mme/images
VSTAR_DATA_PATH=/path/to/vstar/test_questions.jsonl
VSTAR_IMAGE_DIR=/path/to/vstar/images

# Optional Langfuse tracing
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=
